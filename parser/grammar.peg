package parser

type Parser Peg {
    
}

Program <- (Expression Program) / Expression
Expression <- Integer / Identifier / Block / (LPAREN Expression+ RPAREN)
Identifier <- [[a-z]] [[a-z0-9_]]*
Block <- LBRACE Expression* RBRACE

LBRACE <- '{'
RBRACE <- '}'
LPAREN <- '('
RPAREN <- ')'
Digit <- [0-9]
Integer <- Digit+
